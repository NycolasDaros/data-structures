}

Node
element | pointer --> element | pointer




===============================node.hpp=======================================

#include <iostream>
using namespace std;

template <typename T>
struct Node {
    T element;
    Node<T> *next;
};

// LUE (Lista unicamente encadeade)
template <typename T>
struct SingleLinkedList {
    Node<T> *begin;
    Node<T> *end;
};

template <typename T>
void initialize(SingleLinkedList<T> &l) {
    l.begin = NULL;
    l.end = NULL;
};

template <typename T>
bool isEmpty(SingleLinkedList<T> &l) {
    return (l.begin == NULL) ? true : false;
}

