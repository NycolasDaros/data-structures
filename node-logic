LUE (Lista Unicamente Encadeade) Single Linked List

Linked List

linear sequence of nodes alocated in memory, which are linked (connected) through pointers.

node {
  T element;
  Node* next;
}

Node
element | pointer --> element | pointer




===============================node.hpp=======================================



#include <iostream>
using namespace std;

template <typename T>
struct Node {
    T element;
    Node<T> *next;
};

// LUE (Lista unicamente encadeade)
template <typename T>
struct SingleLinkedList {
    Node<T> *begin;
    Node<T> *end;
};

template <typename T>
void initialize(SingleLinkedList<T> *list) {
    list->begin = NULL;
    list->end = NULL;
};

template <typename T>
void show(Node<T> &node) {
    cout << node.element << " " << node.next << endl;
};

